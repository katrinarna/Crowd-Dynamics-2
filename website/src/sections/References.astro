---

<Section id="references" title="References">
  <ol
    class="space-y-2 text-[0.95rem] leading-[1.6]"
    style="counter-reset: ref; padding-left: 0; list-style: none;"
  >
    {refs.map((r, i) => (
      <li
        id={`ref-${i + 1}`}
        class="pl-9 -indent-9"
        style="color: var(--color-ink-soft);"
      >
        <span
          class="inline-block w-7 text-[var(--color-muted)] tabular-nums"
          style="font-family: var(--font-sans);"
        >
          [{i + 1}]
        </span>
        {r.authors} ({r.year}).
        <em>{r.title}</em>
        <span style="color: var(--color-muted);">{r.venue}</span>
      </li>
    ))}
  </ol>
</Section>
